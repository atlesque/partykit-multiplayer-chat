{
  "name": "partykit-multiplayer-chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "typecheck": "nuxt typecheck",
    "test:unit": "vitest run --exclude 'tests/e2e/**'",
    "test:e2e": "playwright test",
    "test:live": "playwright test --config playwright.live.config.ts",
    "dev:party": "partykit dev --port 1999",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "nuxt": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "partykit": "^0.0.115",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.32.1"
}
